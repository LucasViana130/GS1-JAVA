{
  "info": {
    "name": "AgroOrbit API - Global Solution 2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"lucas@agroorbit.com\",\n  \"password\": \"123456\"\n}" }
      }
    },
    { "name": "Dashboard", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/dashboard" } },
    { "name": "List Farms", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/farms" } },
    { "name": "List Crop Areas", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/crop-areas" } },
    { "name": "Create Sensor Reading", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/sensor-readings", "body": { "mode": "raw", "raw": "{\n  \"sensorId\": 1,\n  \"temperature\": 35.2,\n  \"airHumidity\": 27.5,\n  \"soilHumidity\": 22.0,\n  \"manualAlert\": false\n}" } } },
    { "name": "Create Satellite Data", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/satellite-data", "body": { "mode": "raw", "raw": "{\n  \"cropAreaId\": 1,\n  \"source\": \"SENTINEL_HUB_STATISTICAL_API\",\n  \"ndviAverage\": 0.38,\n  \"ndviMin\": 0.25,\n  \"ndviMax\": 0.61,\n  \"surfaceTemperature\": 36.5,\n  \"cloudCoverage\": 18,\n  \"captureDate\": \"2026-06-01\"\n}" } } },
    { "name": "Run Risk Analysis", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/risk-analysis/1" } },
    { "name": "Crop Area Alerts", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/crop-areas/1/alerts" } },
    { "name": "Crop Area Recommendations", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/crop-areas/1/recommendations" } }
  ]
}
